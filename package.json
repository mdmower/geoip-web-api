{
  "name": "geoip-web-api",
  "version": "4.1.2",
  "description": "An AMP-GEO compatible location web API",
  "type": "module",
  "scripts": {
    "build": "npm run lint && npm run clean && npm run compile",
    "clean": "rimraf lib",
    "compile": "tsc --project src/tsconfig.json",
    "compile:debug": "tsc --project src/tsconfig.json --sourceMap",
    "dev": "tsx --watch src/cli.ts --config config.dev.json",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepare": "npm run clean && npm run compile",
    "start": "node lib/cli.js",
    "test": "vitest"
  },
  "engines": {
    "node": ">= 20.19.0"
  },
  "bin": {
    "geoip-web-api": "lib/cli.js"
  },
  "files": [
    "/lib"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdmower/geoip-web-api.git"
  },
  "keywords": [
    "geoip",
    "amp-geo",
    "location",
    "maxmind"
  ],
  "author": "Matt Mower <mdmower@cmphys.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mdmower/geoip-web-api/issues"
  },
  "homepage": "https://github.com/mdmower/geoip-web-api#readme",
  "allowScripts": {
    "esbuild": true
  },
  "dependencies": {
    "express": "^5.2.1",
    "ip2ldb-reader": "^5.0.1",
    "maxmind": "^5.0.6",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.19.43",
    "@vitest/eslint-plugin": "^1.6.21",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.12",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
